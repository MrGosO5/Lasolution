{
  "name": "lasolution-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start:dev": "powershell -ExecutionPolicy Bypass -File .\\start-dev.ps1",
    "start:docker": "powershell -ExecutionPolicy Bypass -File .\\start-docker.ps1",
    "dev": "next dev -p 3001",
    "clean:next": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true}); console.log('removed .next')\"",
    "backend:install": "npm --prefix backend install",
    "backend:generate": "npm --prefix backend run db:generate",
    "backend:dev": "npm --prefix backend run dev",
    "backend:migrate": "npm --prefix backend run db:migrate",
    "db:seed": "npm --prefix backend run db:seed",
    "backend:seed:admin": "npm --prefix backend run db:seed:admin",
    "backend:seed:demo-orders": "npm --prefix backend run db:seed:demo-orders",
    "backend:seed:demo-testimonials": "npm --prefix backend run db:seed:demo-testimonials",
    "docker:db": "docker compose up -d postgres redis",
    "docker:dev": "docker compose --profile dev up -d postgres redis minio mailpit",
    "docker:down": "docker compose --profile dev down",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@emailjs/nodejs": "^5.0.2",
    "country-telephone-data": "^0.6.3",
    "framer-motion": "^11.18.2",
    "iconoir-react": "^7.11.0",
    "next": "14.2.15",
    "next-auth": "^4.24.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3"
  }
}
