# Copier vers `.env.local` — ne jamais committer les vraies valeurs.

# --- Zoho Books ---
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORGANIZATION_ID=
ZOHO_BOOKS_API_BASE=https://www.zohoapis.com
ZOHO_ACCOUNTS_BASE=https://accounts.zoho.com
ZOHO_OAUTH_REDIRECT_URI=http://localhost:4000/admin/integrations/zoho/callback
ZOHO_INVOICE_TAX_RATE=20
ZOHO_INVOICE_CURRENCY=EUR

# --- Airtable ---
AIRTABLE_PAT=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_COLIS=Colis
AIRTABLE_PARAMETRES_RECORD_ID=recn3WIQZNHBhmAhU
# Pull bidirectionnel désactivé par défaut (push-only MVP).
AIRTABLE_PULL_ENABLED=false
AIRTABLE_PULL_INTERVAL_MS=300000
AIRTABLE_ANTI_LOOP_MS=120000

# --- Worker ---
WORKER_POLL_MS=4000
