generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  client
  relais
  solupacker
  solu_livreur
  ambassadeur
}

enum OrderType {
  DIRECT_TO_WAREHOUSE
  CONCIERGE_PURCHASE
}

enum TestimonialStatus {
  PENDING
  APPROVED
  REJECTED
}

model Country {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  currency  String
  createdAt DateTime  @default(now())
  addresses Address[]
}

model User {
  id           String    @id
  email        String    @unique
  name         String?
  role         UserRole
  passwordHash String?
  emailVerifiedAt DateTime?
  failedLoginCount Int @default(0)
  lockedUntil DateTime?
  totpSecret String?
  mfaEnabled Boolean @default(false)
  /// Infos profil vitrine (téléphone, adresse, préférences langue/devise, etc.)
  profile      Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  orders       Order[]
  addresses    Address[]
  wallet       Wallet?
  kycSubmissions KycSubmission[]
  applications   UserApplication[]
  refreshTokens  RefreshToken[]
  testimonials   OrderTestimonial[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  oauthAccounts OAuthAccount[]
}

/// Jeton usage unique pour « mot de passe oublié » (hash stocké, pas le brut).
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model SecurityEvent {
  id        String   @id @default(cuid())
  userId    String?
  email     String?
  type      String
  ip        String?
  userAgent String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([email])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ip        String?
  lastUsedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model OAuthAccount {
  id                String @id @default(cuid())
  userId            String
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model WarehouseAddress {
  id        String   @id @default(cuid())
  label     String
  line1     String
  line2     String?
  postal    String
  city      String
  country   String   @default("FR")
  isDefault Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Address {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  countryId String
  country   Country @relation(fields: [countryId], references: [id])
  line1     String
  line2     String?
  city      String
  postal    String?
  phone     String?
  label     String?
}

model Order {
  id                 String               @id @default(cuid())
  userId             String
  user               User                 @relation(fields: [userId], references: [id])
  type               OrderType
  status             String
  deliveryMode       String?
  proofImageUrl      String
  currency           String               @default("EUR")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  lines              OrderLine[]
  parcels            Parcel[]
  invoices           Invoice[]
  procurement        ProcurementRequest?
  testimonial        OrderTestimonial?
}

/// Avis / témoignage client après livraison (1 par commande ou 1 par demande d'expédition).
model OrderTestimonial {
  id                String            @id @default(cuid())
  orderId           String?           @unique
  order             Order?            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  /// Référence `SecurityEvent.id` (`type: shipping_request`).
  shippingRequestId String?           @unique
  userId            String
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientName        String
  city              String
  country           String
  message           String            @db.Text
  rating            Int?
  photoUrl          String?
  status            TestimonialStatus @default(PENDING)
  isDemo            Boolean           @default(false)
  rejectReason      String?           @db.Text
  reviewedAt        DateTime?
  reviewedBy        String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([userId])
  @@index([status, createdAt])
  @@index([status, isDemo])
  @@index([shippingRequestId])
}

model OrderLine {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(12, 2)
  currency    String
}

model Parcel {
  id               String           @id @default(cuid())
  orderId          String
  order            Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status           String
  weightKg         Decimal?         @db.Decimal(10, 3)
  /// Réception physique à l’entrepôt (lot 1 admin ops).
  receivedAt       DateTime?
  /// Passage en expédié côté entrepôt (lot 1 admin ops).
  shippedAt        DateTime?
  deliveryCodeHash String?
  labelUrl         String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  trackingEvents   TrackingEvent[]
  deliveryJobs     DeliveryJob[]
  incidents        IncidentReport[]
}

model TrackingEvent {
  id        String   @id @default(cuid())
  parcelId  String
  parcel    Parcel   @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  status    String
  message   String?
  meta      Json?
  createdAt DateTime @default(now())
}

model ProcurementRequest {
  id        String            @id @default(cuid())
  orderId   String            @unique
  order     Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    String
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  lines     ProcurementLine[]
}

model ProcurementLine {
  id         String               @id @default(cuid())
  requestId  String
  request    ProcurementRequest   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  productUrl String?
  label      String
  maxBudget  Decimal?             @db.Decimal(12, 2)
  currency   String?
}

model Invoice {
  id              String        @id @default(cuid())
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id])
  status          String
  zohoDraftId     String?
  zohoInvoiceId   String?
  zohoSyncStatus  String?
  lastSyncError   String?
  fxRateUsed      Decimal?      @db.Decimal(18, 8)
  currency        String        @default("EUR")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  lines           InvoiceLine[]
  payments        Payment[]
}

model InvoiceLine {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  label     String
  amount    Decimal @db.Decimal(12, 2)
  taxRate   Decimal? @db.Decimal(5, 2)
}

model Payment {
  id                 String    @id @default(cuid())
  invoiceId          String?
  invoice            Invoice?  @relation(fields: [invoiceId], references: [id])
  provider           String
  providerIntentId   String?   @unique
  idempotencyKey     String?   @unique
  amount             Decimal   @db.Decimal(12, 2)
  currency           String
  status             String
  rawMeta            Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model WebhookEvent {
  id          String    @id @default(cuid())
  provider    String
  eventId     String
  payload     Json
  processedAt DateTime?
  error       String?

  @@unique([provider, eventId])
}

model PaymentProvider {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model PaymentMethodConfig {
  id           String   @id @default(cuid())
  countryCode  String
  currency     String
  methodCode   String
  providerCode String
  priority     Int      @default(1)
  active       Boolean  @default(true)

  @@index([countryCode, currency])
}

model Wallet {
  id        String        @id @default(cuid())
  userId    String        @unique
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency  String        @default("XOF")
  createdAt DateTime      @default(now())
  entries   LedgerEntry[]
}

model LedgerEntry {
  id        String   @id @default(cuid())
  walletId  String
  wallet    Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(12, 2)
  type      String
  reference String?
  meta      Json?
  createdAt DateTime @default(now())
}

model PayoutRequest {
  id        String   @id @default(cuid())
  userId    String
  amount    Decimal  @db.Decimal(12, 2)
  currency  String
  status    String
  provider  String?
  createdAt DateTime @default(now())
}

model DeliveryJob {
  id           String    @id @default(cuid())
  parcelId     String
  parcel       Parcel    @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  driverUserId String?
  status       String
  fee          Decimal?  @db.Decimal(12, 2)
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model DriverShift {
  id      String   @id @default(cuid())
  userId  String
  startAt DateTime
  endAt   DateTime
  zoneId  String?
}

model Announcement {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      Json?
  status    String
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  missions  Mission[]
}

model Mission {
  id             String       @id @default(cuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  packerUserId   String
  status         String
  createdAt      DateTime     @default(now())
}

model IncidentReport {
  id        String   @id @default(cuid())
  parcelId  String
  parcel    Parcel   @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  message   String
  mediaUrls String[]
  createdAt DateTime @default(now())
}

model InAppMessage {
  id        String    @id @default(cuid())
  audience  String
  title     String
  body      String
  priority  Int       @default(0)
  readAt    DateTime?
  userId    String?
  createdAt DateTime  @default(now())
}

model CommissionStatement {
  id        String   @id @default(cuid())
  userId    String
  period    String
  pdfUrl    String?
  createdAt DateTime @default(now())
}

model KycSubmission {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      UserRole
  status    String
  payload   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserApplication {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      UserRole
  status    String
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())
}
